{
  "name": "lab-tracker-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "zenoti:once": "tsx scripts/zenoti-sync.ts",
    "zenoti:loop": "while true; do tsx scripts/zenoti-sync.ts; sleep 60; done",
    "pb:worker": "tsx scripts/pb-upload-worker.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:auto-attach": "tsx scripts/auto-attach-test-pdf.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "fastify": "^5.2.1",
    "playwright": "^1.49.1",
    "undici": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
